<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CK3_Reader"
        x:Class="CK3_Reader.MainWindow"
        mc:Ignorable="d"
        Title="CK3 Voice Reader" Height="350" Width="500" FontSize="13" Closing="Window_closing"
        ResizeMode="CanMinimize">

    <Grid Background="#FF2C3E50">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#FF1A252F" Padding="15,10">
            <TextBlock Text="🎭 CK3 Voice Reader" FontSize="16" FontWeight="Bold" Foreground="White"/>
        </Border>
        
        <!-- Setup Section -->
        <Border Grid.Row="1" Background="#FF34495E" Padding="20" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left Column: API Keys -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="API KEYS" FontWeight="Bold" FontSize="11" Foreground="White" Margin="0,0,0,10"/>
                    
                    <!-- Claude API Key -->
                    <TextBlock Text="Claude" Foreground="White" FontSize="11" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="txtApiKey" FontSize="11" Margin="0,0,0,4" PasswordChanged="TxtApiKey_PasswordChanged"/>
                    <TextBlock x:Name="txtApiStatus" Text="⚠️ Not set" Foreground="#FFFFCC00" FontSize="10" Margin="0,0,0,12"/>
                    
                    <!-- ElevenLabs API Key -->
                    <TextBlock Text="ElevenLabs" Foreground="White" FontSize="11" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="txtElevenLabsApiKey" FontSize="11" Margin="0,0,0,4" PasswordChanged="TxtElevenLabsApiKey_PasswordChanged"/>
                    <TextBlock x:Name="txtElevenLabsStatus" Text="⚠️ Not set" Foreground="#FFFFCC00" FontSize="10"/>
                </StackPanel>
                
                <!-- Right Column: Controls -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="CONTROLS" FontWeight="Bold" FontSize="11" Foreground="White" Margin="0,0,0,10"/>
                    
                    <!-- Volume -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔊" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider x:Name="volumeSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,10,0"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                        <TextBlock x:Name="volumeLabel" Grid.Column="2" Text="100%" Foreground="White"
                                   FontSize="11" VerticalAlignment="Center" Width="40"/>
                    </Grid>
                    
                    <!-- Speed -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚡" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider x:Name="speedSlider" Grid.Column="1" Minimum="50" Maximum="200" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,10,0"
                                ValueChanged="SpeedSlider_ValueChanged"/>
                        <TextBlock x:Name="speedLabel" Grid.Column="2" Text="1.0x" Foreground="White"
                                   FontSize="11" VerticalAlignment="Center" Width="40"/>
                    </Grid>
                    
                    <!-- Stop Button -->
                    <Button x:Name="btnStopVoice" Content="⏹️ Stop Playback"
                            FontSize="11" FontWeight="Bold"
                            Background="#FFE74C3C" Foreground="White"
                            Padding="12,8" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            Click="BtnStopVoice_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFE74C3C"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFC0392B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Status Section -->
        <Border Grid.Row="2" Background="#FF1A252F" Padding="15" Margin="15,0,15,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <!-- Status Text -->
                    <TextBlock x:Name="txtStatus"
                               Text="Status: Waiting for CK3 events"
                               FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                    
                    <!-- Loading Indicator (hidden by default) -->
                    <TextBlock x:Name="loadingSpinner"
                               Text="" FontSize="13" Foreground="White"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
                
                <!-- Mode Indicator -->
                <TextBlock x:Name="txtModeInfo"
                           Text=""
                           FontSize="9" Foreground="#FF95A5A6"
                           Margin="0,3,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
