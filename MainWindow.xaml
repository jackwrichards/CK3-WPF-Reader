<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CK3_Reader"
        x:Class="CK3_Reader.MainWindow"
        mc:Ignorable="d"
        Title="CK3 Voice Reader" Height="900" Width="1120" FontSize="16" Closing="Window_closing">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#FF34495E" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Getting Started Section -->
                    <Border Background="#FF2C3E50" Padding="10" CornerRadius="5" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="🚀 GETTING STARTED" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,0,0,10"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#FFCCCCCC" FontSize="12" Margin="0,0,0,5">
                                <Run Text="1. Enter your Claude API key below"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#FFCCCCCC" FontSize="12" Margin="0,0,0,5">
                                <Run Text="2. Enter your ElevenLabs API key"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#FFCCCCCC" FontSize="12" Margin="0,0,0,5">
                                <Run Text="3. Launch CK3 and trigger an event!"/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,5,0,0" FontStyle="Italic">
                                <Run Text="Get API keys from:"/>
                                <LineBreak/>
                                <Run Text="• console.anthropic.com"/>
                                <LineBreak/>
                                <Run Text="• elevenlabs.io"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- API Keys Section -->
                    <TextBlock Text="API KEYS" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Claude API Key:" Foreground="White" FontSize="12" Margin="0,0,0,5"
                               ToolTip="Your Anthropic Claude API key for AI text processing"/>
                    <PasswordBox x:Name="txtApiKey" FontSize="12" Margin="0,0,0,10" PasswordChanged="TxtApiKey_PasswordChanged"
                                 ToolTip="Paste your Claude API key here (starts with 'sk-ant-')"/>
                    
                    <TextBlock x:Name="txtApiStatus" Text="⚠️ No API key set" Foreground="#FFFFCC00" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="ElevenLabs API Key:" Foreground="White" FontSize="12" Margin="0,0,0,5"
                               ToolTip="Your ElevenLabs API key for text-to-speech"/>
                    <PasswordBox x:Name="txtElevenLabsApiKey" FontSize="12" Margin="0,0,0,10" PasswordChanged="TxtElevenLabsApiKey_PasswordChanged"
                                 ToolTip="Paste your ElevenLabs API key here"/>
                    
                    <TextBlock x:Name="txtElevenLabsStatus" Text="⚠️ No API key set" Foreground="#FFFFCC00" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <!-- Basic Controls -->
                    <TextBlock Text="PLAYBACK CONTROLS" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,10,0,10"/>
                    
                    <TextBlock Text="Volume:" Foreground="White" FontSize="12" Margin="0,0,0,5"
                               ToolTip="Adjust the volume of the voice playback (0-100%)"/>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="volumeSlider" Grid.Column="0" Minimum="0" Maximum="100" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,10,0"
                                ValueChanged="VolumeSlider_ValueChanged"
                                ToolTip="Drag to adjust volume"/>
                        <TextBlock x:Name="volumeLabel" Grid.Column="1" Text="100%" Foreground="White"
                                   FontSize="11" VerticalAlignment="Center" Width="40"/>
                    </Grid>
                    <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,10">
                        <Run Text="Controls how loud the voice playback is. 100% = full volume, 0% = muted."/>
                    </TextBlock>
                    
                    <TextBlock Text="Playback Speed:" Foreground="White" FontSize="12" Margin="0,0,0,5"
                               ToolTip="Adjust how fast the voice speaks (0.5x = slower, 2.0x = faster)"/>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="speedSlider" Grid.Column="0" Minimum="50" Maximum="200" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,10,0"
                                ValueChanged="SpeedSlider_ValueChanged"
                                ToolTip="Drag to adjust speed (1.0x = normal)"/>
                        <TextBlock x:Name="speedLabel" Grid.Column="1" Text="1.0x" Foreground="White"
                                   FontSize="11" VerticalAlignment="Center" Width="40"/>
                    </Grid>
                    <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,10">
                        <Run Text="Changes how fast the voice speaks. 1.0x = normal speed, 0.5x = half speed (slower), 2.0x = double speed (faster)."/>
                    </TextBlock>
                    
                    <Button x:Name="btnStopVoice" Content="⏹️ Stop Voice"
                            FontSize="12" FontWeight="Bold"
                            Background="#FFE74C3C" Foreground="White"
                            Padding="10,8,10,8" Margin="0,0,0,5"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnStopVoice_Click"
                            ToolTip="Stop the currently playing voice">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFE74C3C"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFC0392B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,15">
                        <Run Text="Immediately stops any voice that is currently playing. Useful if you want to skip to the next event."/>
                    </TextBlock>

                    <!-- Advanced Settings Expander -->
                    <Expander Header="⚙️ ADVANCED SETTINGS" Foreground="White" FontWeight="Bold" FontSize="13" Margin="0,10,0,10" IsExpanded="False">
                        <StackPanel Margin="0,10,0,0">
                            
                            <!-- Processing Mode -->
                            <TextBlock Text="Processing Mode:" Foreground="White" FontSize="12" Margin="0,0,0,5"
                                       ToolTip="Choose how events are processed"/>
                            <CheckBox x:Name="skipOpenAICheckbox" Content="Fast Mode (Skip AI Processing)"
                                      Foreground="White" FontSize="11" Margin="0,0,0,5"
                                      IsChecked="False" Checked="SkipOpenAICheckbox_Changed" Unchecked="SkipOpenAICheckbox_Changed"
                                      ToolTip="Enable for faster processing without Claude AI enhancement. Uses ElevenLabs Flash v2.5 directly."/>
                            <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,15">
                                <Run Text="When enabled, skips Claude AI processing and sends text directly to ElevenLabs Flash v2.5. Faster but less dramatic/expressive. Disable for multi-speaker dialogue with emotion tags."/>
                            </TextBlock>
                            
                            <!-- Voice Quality Settings -->
                            <TextBlock Text="VOICE QUALITY" FontWeight="Bold" FontSize="12" Foreground="White" Margin="0,10,0,10"/>
                            
                            <TextBlock Text="Stability:" Foreground="White" FontSize="11" Margin="0,0,0,5"
                                       ToolTip="Higher = more consistent voice, Lower = more expressive (0.0-1.0)"/>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="stabilitySlider" Grid.Column="0" Minimum="0" Maximum="100" Value="25"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" Margin="0,0,10,0"
                                        ValueChanged="StabilitySlider_ValueChanged"
                                        ToolTip="Recommended: 0.25 for maximum realism and expressiveness"/>
                                <TextBlock x:Name="stabilityLabel" Grid.Column="1" Text="0.25" Foreground="White"
                                           FontSize="11" VerticalAlignment="Center" Width="40"/>
                            </Grid>
                            <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,10">
                                <Run Text="Controls voice consistency. Higher values (0.7-1.0) = more predictable and stable voice. Lower values (0.0-0.4) = more varied and expressive. Recommended: 0.25 for MAXIMUM realism and human-like variation."/>
                            </TextBlock>
                            
                            <TextBlock Text="Similarity Boost:" Foreground="White" FontSize="11" Margin="0,0,0,5"
                                       ToolTip="Higher = closer to original voice, Lower = more creative (0.0-1.0)"/>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="similaritySlider" Grid.Column="0" Minimum="0" Maximum="100" Value="85"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" Margin="0,0,10,0"
                                        ValueChanged="SimilaritySlider_ValueChanged"
                                        ToolTip="Recommended: 0.85 for maximum voice clarity"/>
                                <TextBlock x:Name="similarityLabel" Grid.Column="1" Text="0.85" Foreground="White"
                                           FontSize="11" VerticalAlignment="Center" Width="40"/>
                            </Grid>
                            <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,10">
                                <Run Text="Enhances similarity to the original voice. Higher values (0.7-1.0) = stays closer to the voice's natural sound. Lower values (0.0-0.3) = more creative interpretation. Recommended: 0.85 for MAXIMUM clarity and natural sound."/>
                            </TextBlock>
                            
                            <TextBlock Text="Style/Expressiveness:" Foreground="White" FontSize="11" Margin="0,0,0,5"
                                       ToolTip="Higher = more dramatic and expressive (0.0-1.0)"/>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="styleSlider" Grid.Column="0" Minimum="0" Maximum="100" Value="65"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" Margin="0,0,10,0"
                                        ValueChanged="StyleSlider_ValueChanged"
                                        ToolTip="Recommended: 0.65 for maximum emotional realism"/>
                                <TextBlock x:Name="styleLabel" Grid.Column="1" Text="0.65" Foreground="White"
                                           FontSize="11" VerticalAlignment="Center" Width="40"/>
                            </Grid>
                            <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,10">
                                <Run Text="Controls how expressive and dramatic the voice is. 0.0 = neutral/flat delivery. 0.5 = natural emotion. 0.7-1.0 = very theatrical. Recommended: 0.65 for MAXIMUM emotional realism - voices will sound like they're truly experiencing the events!"/>
                            </TextBlock>
                            
                            <CheckBox x:Name="speakerBoostCheckbox" Content="Use Speaker Boost"
                                      Foreground="White" FontSize="11" Margin="0,0,0,5"
                                      IsChecked="True" Checked="SpeakerBoostCheckbox_Changed" Unchecked="SpeakerBoostCheckbox_Changed"
                                      ToolTip="Enhances voice clarity for multi-speaker dialogue (recommended: ON)"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,15">
                                <Run Text="Boosts voice clarity and distinction when multiple speakers are in the same dialogue. Recommended: Keep ON for better multi-speaker conversations."/>
                            </TextBlock>
                            
                            <!-- Voice Customization -->
                            <TextBlock Text="VOICE CUSTOMIZATION" FontWeight="Bold" FontSize="12" Foreground="White" Margin="0,10,0,10"/>
                            
                            <TextBlock Text="Narrator Voice ID:" Foreground="White" FontSize="11" Margin="0,0,0,5"
                                       ToolTip="ElevenLabs voice ID for the main narrator (Daniel by default)"/>
                            <TextBox x:Name="txtDanielVoiceId" FontSize="11" Margin="0,0,0,5"
                                     ToolTip="Enter a custom ElevenLabs voice ID or leave default"
                                     TextChanged="TxtDanielVoiceId_TextChanged"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,15">
                                <Run Text="The ElevenLabs voice ID used for the main narrator (Daniel). You can replace this with any ElevenLabs voice ID from your account. Also used in Fast Mode."/>
                            </TextBlock>
                            
                        </StackPanel>
                    </Expander>

                    <!-- Debug Mode Toggle -->
                    <CheckBox x:Name="debugModeCheckbox" Content="🐛 Debug Mode (Show Technical Details)"
                              Foreground="White" FontSize="11" Margin="0,15,0,5"
                              IsChecked="False" Checked="DebugModeCheckbox_Changed" Unchecked="DebugModeCheckbox_Changed"
                              ToolTip="Show raw logs, cleaned text, and parsed dialogue for troubleshooting"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#FF95A5A6" FontSize="11" Margin="0,0,0,10">
                        <Run Text="Shows technical details like raw CK3 logs, cleaned text, AI translation, and parsed dialogue. Useful for troubleshooting voice issues or understanding how the app processes events."/>
                    </TextBlock>
                    
                    <TextBlock x:Name="txtModeInfo" TextWrapping="Wrap" Text="Events will be automatically processed with Claude and played via ElevenLabs TTS. Settings are saved automatically."
                               FontSize="11" Foreground="#FFCCCCCC" Margin="0,0,0,10"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Status Section -->
                    <Border Background="#FF2C3E50" Padding="15,10,15,10" CornerRadius="5" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="STATUS" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtStatus" TextWrapping="Wrap" Text="Initializing..." FontSize="16" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- Current Event Section -->
                    <Border Background="White" Padding="15,10,15,10" CornerRadius="5" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="0,0,0,15">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="250">
                            <StackPanel>
                                <TextBlock Text="CURRENT EVENT" FontWeight="Bold" FontSize="14" Foreground="#FF2C3E50" Margin="0,0,0,10"/>
                                <TextBox x:Name="txtCurrentEvent" TextWrapping="Wrap" Text="Waiting for game events..." FontSize="16" Foreground="#FF333333"
                                         IsReadOnly="True" BorderThickness="0" Background="Transparent" Cursor="Arrow"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Debug Sections (Hidden by default) -->
                    <StackPanel x:Name="debugPanel" Visibility="Collapsed">
                        
                        <!-- CK3 Log Content Section -->
                        <Border Background="White" Padding="15,10,15,10" CornerRadius="5" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="0,0,0,15">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                <StackPanel>
                                    <TextBlock Text="CK3 LOG CONTENT (Debug)" FontWeight="Bold" FontSize="14" Foreground="#FF2C3E50" Margin="0,0,0,10"/>
                                    <TextBox x:Name="txtEvent" TextWrapping="Wrap" Text="Waiting for game events..." FontSize="14" Foreground="#FF333333"
                                             IsReadOnly="True" BorderThickness="0" Background="Transparent" Cursor="Arrow" FontFamily="Consolas"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- LLM Translation Section -->
                        <Border Background="#FFF8F9FA" Padding="15,10,15,10" CornerRadius="5" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="0,0,0,15">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="250">
                                <StackPanel>
                                    <TextBlock Text="AI TRANSLATION (Debug)" FontWeight="Bold" FontSize="14" Foreground="#FF2C3E50" Margin="0,0,0,10"/>
                                    <TextBox x:Name="txtLlmTranslation" TextWrapping="Wrap" Text="AI translation will appear here after events are detected..." FontSize="14" Foreground="#FF555555"
                                             IsReadOnly="True" BorderThickness="0" Background="Transparent" Cursor="Arrow"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Parsed Dialogue Section -->
                        <Border Background="#FFFFF3E0" Padding="15,10,15,10" CornerRadius="5" BorderBrush="#FFFFB74D" BorderThickness="1" Margin="0,0,0,15">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                <StackPanel>
                                    <TextBlock Text="PARSED DIALOGUE - Multi-Speaker (Debug)" FontWeight="Bold" FontSize="14" Foreground="#FF2C3E50" Margin="0,0,0,10"/>
                                    <TextBox x:Name="txtParsedDialogue" TextWrapping="Wrap" Text="Parsed dialogue entries will appear here..." FontSize="12" Foreground="#FF555555"
                                             IsReadOnly="True" BorderThickness="0" Background="Transparent" Cursor="Arrow" FontFamily="Consolas"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <!-- ElevenLabs Status Section -->
                    <Border Background="#FFE8F5E9" Padding="15,10,15,10" CornerRadius="5" BorderBrush="#FF81C784" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="VOICE PLAYBACK STATUS" FontWeight="Bold" FontSize="14" Foreground="#FF2C3E50" Margin="0,0,0,10"/>
                            <TextBox x:Name="txtElevenLabsTtsStatus" TextWrapping="Wrap" Text="Waiting for events..." FontSize="16" Foreground="#FF555555"
                                     IsReadOnly="True" BorderThickness="0" Background="Transparent" Cursor="Arrow"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
